# Environment
ENVIRONMENT=development

# Database
DB_HOST=db.xxxxxxxx.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_SSL_MODE=require

# API Security 
JWT_SECRET_KEY=your-super-secret-jwt-key-min-32-chars-long
API_KEY=your-secure-api-key-for-service-access

# Frontend
API_BASE_URL=http://localhost:8000
CORS_ORIGINS=["http://localhost:3000","https://f1-platform.vercel.app"]

# Redis (Optional)
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false

# APIs
ERGAST_API_BASE=https://ergast.com/api/f1
OPENF1_API_BASE=https://api.openf1.org/v1
FASTF1_CACHE_DIR=./data/fastf1_cache

# AWS / Vault (Production)
AWS_REGION=us-east-1
AWS_SECRET_NAME=f1-prediction-db-credentials
VAULT_ADDR=https://vault.yourcompany.com:8200
VAULT_TOKEN=your_vault_token

# Logging & Observability
LOG_LEVEL=INFO
LOG_FORMAT=json
PROMETHEUS_PORT=8000